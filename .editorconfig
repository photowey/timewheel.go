root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = tab

[go.mod]
indent_style = tab
indent_size = tab

[Makefile]
indent_style = tab
indent_size = tab

[*.{md,yml,yaml,json,toml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
